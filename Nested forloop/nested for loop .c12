 #include <stdio.h>

int main() {
    int n, i, j, spaces;
    scanf("%d", &n);
    for (i = 1; i <= n; i++) {
        for (j = 1; j <= i; j++) {
            printf("%d", j);
        }
        spaces = 2 * (n - i);
        for (j = 1; j <= spaces; j++) {
            printf(" ");
        }
        for (j = i; j >= 1; j--) {
            printf("%d", j);
        }
        printf("\n");
    }

    return 0;
}
